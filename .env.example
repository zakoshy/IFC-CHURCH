# ==========================================
# IFC CHURCH - ENVIRONMENT CONFIGURATION
# ==========================================

# GEMINI AI (Required for Scripture Counseling)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# SUPABASE (Required for Database & Auth)
# Get these from your Supabase Project Settings > API
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key"

# M-PESA DARAJA (For Giving Integration)
# Get these from: https://developer.safaricom.co.ke/
MPESA_SHORTCODE="174379"
MPESA_PASSKEY="bfb279f..."
MPESA_CONSUMER_KEY="your-consumer-key"
MPESA_CONSUMER_SECRET="your-consumer-secret"
MPESA_CALLBACK_URL="https://your-app.com/api/mpesa/callback"

# APP SETTINGS
# Automatically set in AI Studio, but useful for local dev
APP_URL="http://localhost:3000"
